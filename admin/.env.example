# Local admin should usually call /api (same-origin) and use Vite proxy.
# Set proxy target to local API or remote API.
VITE_PROXY_API_TARGET=https://www.ntdev.lt

# Optional: force direct cross-origin calls from browser (not recommended in local dev).
# VITE_FORCE_CROSS_ORIGIN=true

# Optional explicit base URL override.
# VITE_API_BASE_URL=https://www.ntdev.lt
